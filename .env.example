# Credentials for Intervals.icu
# Get your API key from Intervals.icu -> Settings -> API keys
INTERVALS_API_KEY=your_intervals_api_key_here
# Your athlete ID (e.g. i123456)
INTERVALS_ATHLETE_ID=your_athlete_id_here

# Credentials for Gemini AI (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# ntfy.sh topic for notifications (use a unique name to protect your privacy)
NTFY_TOPIC=your_unique_ntfy_topic_here

# Personalization Settings
ATHLETE_NAME=Athlete

# Health Baseline Settings
# Your baseline HRV value
BASELINE_HRV=100.0
# Normal range for your HRV (used by the AI to detect fatigue)
BASELINE_HRV_MIN=60.0
BASELINE_HRV_MAX=110.0
# Target sleep duration in hours
GOAL_SLEEP=8.0

# System Settings
# Gemini model name (e.g. gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Timezone (e.g. America/Sao_Paulo or America/New_York)
TIMEZONE=America/Sao_Paulo
